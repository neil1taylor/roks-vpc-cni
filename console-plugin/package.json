{
  "name": "vpc-network-management-plugin",
  "version": "1.0.0",
  "private": true,
  "consolePlugin": {
    "name": "vpc-network-management",
    "version": "1.0.0",
    "displayName": "VPC Network Management",
    "description": "Manage IBM VPC networking resources for KubeVirt workloads",
    "exposedModules": {
      "VPCDashboard": "./src/pages/VPCDashboardPage",
      "SubnetsList": "./src/pages/SubnetsListPage",
      "SubnetDetail": "./src/pages/SubnetDetailPage",
      "VNIsList": "./src/pages/VNIsListPage",
      "VNIDetail": "./src/pages/VNIDetailPage",
      "VLANAttachments": "./src/pages/VLANAttachmentsPage",
      "FloatingIPs": "./src/pages/FloatingIPsPage",
      "FloatingIPDetail": "./src/pages/FloatingIPDetailPage",
      "SecurityGroupsList": "./src/pages/SecurityGroupsListPage",
      "SecurityGroupDetail": "./src/pages/SecurityGroupDetailPage",
      "NetworkACLsList": "./src/pages/NetworkACLsListPage",
      "NetworkACLDetail": "./src/pages/NetworkACLDetailPage",
      "Topology": "./src/pages/TopologyPage",
      "Routes": "./src/pages/RoutesPage",
      "NetworksList": "./src/pages/NetworksListPage",
      "NetworkDetail": "./src/pages/NetworkDetailPage",
      "ReservedIPs": "./src/pages/ReservedIPsPage",
      "GatewaysListPage": "./src/plugin-gateways.ts",
      "GatewayDetailPage": "./src/pages/GatewayDetailPage",
      "RoutersListPage": "./src/plugin-routers.ts",
      "RouterDetailPage": "./src/pages/RouterDetailPage"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "dependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.20.0",
    "@patternfly/react-core": "^5.0.0",
    "@patternfly/react-icons": "^5.0.0",
    "@patternfly/react-table": "^5.0.0",
    "@patternfly/react-topology": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.20.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.0",
    "css-loader": "^6.8.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^29.7.0",
    "react-router-dom": "^5.3.0",
    "react-router-dom-v5-compat": "^6.0.0",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "scripts": {
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "start": "webpack serve --mode=development",
    "ts-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live:login": "ts-node e2e/live/login.ts",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "test:e2e:live:headed": "playwright test --config playwright.live.config.ts --headed",
    "test:e2e:live:ui": "playwright test --config playwright.live.config.ts --ui",
    "test": "jest",
    "test:harness": "webpack serve --config webpack.config.test.js"
  }
}
